  "name": "Journey Buddi — DEV",
  "values": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "default",
      "enabled": true,
      "description": "Local FastAPI server"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "secret",
