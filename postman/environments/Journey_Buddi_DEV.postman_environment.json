    {
      "key": "user_email",
      "value": "dev@example.com",
      "type": "default",
      "enabled": true,
      "description": "Email used for magic-link auth requests"
    },
    {
      "key": "trip_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Trips / Create Trip"
    },
    {
      "key": "conversation_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Conversations / Create Conversation"
    },
    {
      "key": "swap_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Briefings / List Swap Suggestions"
    },
    {
      "key": "attraction_slug",
      "value": "milford-sound-cruise",
      "type": "default",
      "enabled": true,
