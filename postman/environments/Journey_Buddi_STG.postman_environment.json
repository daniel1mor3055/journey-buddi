{
  "id": "env-journey-buddi-stg",
  "name": "Journey Buddi — STG",
  "values": [
    {
      "key": "base_url",
      "value": "https://journey-buddi-api-staging.up.railway.app",
      "type": "default",
      "enabled": true,
      "description": "Railway staging deployment — update URL once provisioned"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Auto-populated by Auth / Verify Magic Link. Magic link arrives via email in STG."
    },
    {
      "key": "user_email",
      "value": "staging@example.com",
      "type": "default",
      "enabled": true,
      "description": "Email used for magic-link auth requests in staging"
    },
    {
      "key": "trip_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Trips / Create Trip"
    },
    {
      "key": "conversation_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Conversations / Create Conversation"
    },
    {
      "key": "swap_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Briefings / List Swap Suggestions"
    },
    {
      "key": "attraction_slug",
      "value": "milford-sound-cruise",
      "type": "default",
      "enabled": true,
      "description": "Slug for single-attraction requests"
    },
    {
      "key": "day_number",
      "value": "1",
      "type": "default",
      "enabled": true,
      "description": "Itinerary day number (1-based)"
    }
  ],
  "_postman_variable_scope": "environment",
  "_postman_exported_using": "Postman/11.x"
}
