{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Journey Buddi API",
    "description": "Complete API collection for Journey Buddi — AI-powered adaptive travel companion.\n\n## Quick Start\n1. Select your environment (DEV / STG / PROD) from the top-right dropdown\n2. Run **Auth → Request Magic Link** with your email\n3. In DEV: copy the token from the backend logs. In STG/PROD: check your inbox.\n4. Run **Auth → Verify Magic Link** — `access_token` is auto-captured into the environment\n5. All subsequent authenticated requests will use the token automatically\n\n## Variables Auto-Captured\n- `access_token` — from Auth / Verify Magic Link\n- `trip_id` — from Trips / Create Trip\n- `conversation_id` — from Conversations / Create Conversation\n- `swap_id` — from Briefings / List Swap Suggestions\n\n## Auth\nAll protected routes use **Bearer Token** inherited from the collection. No-auth routes override with `No Auth`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "description": "Overridden per environment — do not edit here"
    },
    {
      "key": "access_token",
      "value": "",
      "description": "Auto-populated by Auth / Verify Magic Link test script"
    },
    {
      "key": "trip_id",
      "value": "",
      "description": "Auto-populated by Trips / Create Trip test script"
    },
    {
      "key": "conversation_id",
      "value": "",
      "description": "Auto-populated by Conversations / Create Conversation test script"
    },
    {
      "key": "swap_id",
      "value": "",
      "description": "Auto-populated by Briefings / List Swap Suggestions test script"
    },
    {
      "key": "attraction_slug",
      "value": "milford-sound-cruise",
      "description": "Slug of the attraction to fetch — update as needed"
    },
    {
      "key": "day_number",
      "value": "1",
      "description": "Itinerary day number (1-based)"
    },
    {
      "key": "user_email",
      "value": "you@example.com",
      "description": "Email to use for magic-link auth"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Service liveness check — no auth required.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns the API status and version. No auth required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is healthy', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('healthy');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Magic-link authentication flow (no passwords). Tokens expire in 30 days.",
      "item": [
        {
          "name": "Request Magic Link",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/magic-link",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "magic-link"]
            },
            "description": "Sends a magic link to the provided email. In DEV mode the link is printed to the backend logs instead of being emailed."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Message returned', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.include('Magic link');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Verify Magic Link",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_MAGIC_LINK_TOKEN_HERE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "verify"]
            },
            "description": "Exchanges the magic-link JWT for an access token. Creates the user account on first login. The `access_token` is auto-saved to the environment."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "const body = pm.response.json();",
                  "if (body.access_token) {",
                  "  pm.environment.set('access_token', body.access_token);",
                  "  console.log('✅ access_token saved to environment');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Issues a new access token for the currently authenticated user. Updates the environment `access_token`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "const body = pm.response.json();",
                  "if (body.access_token) {",
                  "  pm.environment.set('access_token', body.access_token);",
                  "  console.log('✅ access_token refreshed');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Stateless logout — the server returns a success message. The client must discard its token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "// Clear local token after logout",
                  "pm.environment.set('access_token', '');",
                  "console.log('🔓 access_token cleared from environment');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
